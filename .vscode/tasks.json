{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C with Git Bash",
            "type": "shell",
            "command": "gcc -g \"${file}\" -o \"${fileBasenameNoExtension}.exe\"",
            "options": {
                "cwd": "${fileDirname}",
                "shell": {
                    "executable": "C:\\Program Files\\Git\\bin\\bash.exe",
                    "args": ["-lc"]
                }
            },
            "problemMatcher": ["$gcc"],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}